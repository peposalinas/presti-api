# =========================================================
# CONFIGURACIÓN DE LA APLICACIÓN
# =========================================================

# Entorno de ejecución: development | production | test
NODE_ENV=development

# Puerto en el que escucha la API
PORT=3000


# =========================================================
# BASE DE DATOS - Supabase (PostgreSQL)
# =========================================================
# Encontrás estos datos en: Supabase Dashboard → Settings → Database

# Host de la base de datos (Session Pooler o Direct Connection)
DB_HOST=db.<project-ref>.supabase.co

# Puerto (5432 para conexión directa, 5432/6543 para pooler)
DB_PORT=5432

# Usuario de la base de datos
DB_USERNAME=postgres

# Contraseña de la base de datos (la que configuraste al crear el proyecto)
DB_PASSWORD=

# Nombre de la base de datos (por defecto "postgres" en Supabase)
DB_DATABASE=postgres


# =========================================================
# AUTENTICACIÓN - JWT
# =========================================================
# Secreto para firmar los tokens JWT. Usá un string largo y aleatorio en producción.
# Podés generar uno con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# Tiempo de expiración del token (ej: 7d, 24h, 3600s)
JWT_EXPIRES_IN=7d


# =========================================================
# APIs EXTERNAS - BCRA (Central de Deudores)
# =========================================================
# API pública del Banco Central de la República Argentina.
# No requiere autenticación.
# Documentación: https://api.bcra.gob.ar/centraldedeudores/v1.0/swagger/index.html

BCRA_BASE_URL=https://api.bcra.gob.ar


# =========================================================
# APIs EXTERNAS - VERAZ
# =========================================================
# Servicio privado de informes crediticios (Equifax Argentina).
# Requiere contrato comercial previo.

VERAZ_BASE_URL=https://api.veraz.com.ar
VERAZ_USERNAME=
VERAZ_PASSWORD=
VERAZ_API_KEY=
